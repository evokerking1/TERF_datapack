$kill @e[type=text_display,tag=terf_stfr_shutdown_fail_flare,tag=terf_related_$(machine_id)]

execute if score @s terf_data_Ab matches 695 run scoreboard players set @a[distance=..256] terf_shake_frequency 300
execute if score @s terf_data_Ab matches 695 run scoreboard players set @a[distance=..256] terf_shake_magnitude 20
execute if score @s terf_data_Ab matches 695 run scoreboard players add @a[distance=..256] terf_data_P 60
$execute if score @s terf_data_Ab matches 695 as @e[tag=terf_related_$(machine_id),type=item_display,tag=terf_stab_rotor] at @s run data merge entity @s {transformation:{right_rotation:{axis:[1.0f,1.0f,0.0f],angle:0.1}}}

