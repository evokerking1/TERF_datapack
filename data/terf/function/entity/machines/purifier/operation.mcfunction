execute if score @s terf_data_A matches 100.. run scoreboard players set @s terf_data_A 0
execute if score @s terf_data_B matches 100.. run scoreboard players set @s terf_data_B 0
execute if block ~ ~ ~ stone run setblock ~ ~ ~ calcite
execute if block ~ ~ ~ basalt run setblock ~ ~ ~ blackstone
execute if block ~ ~ ~ red_sandstone run setblock ~ ~ ~ netherrack
execute if block ~ ~ ~ mud run setblock ~ ~ ~ clay
