## Start meltdown if it has no containment but has stored power
execute unless entity @s[tag=terf_containment] run return run execute if score @s terf_data_A matches 0 if score @s terf_data_F matches 1.. run function terf:entity/machines/warp_core/states/overload/start

## Otherwise, charge warp core if it has containment
scoreboard players operation temp terf_states = @s datapipes_lib_power_storage
scoreboard players operation temp terf_states /= warp_core_power_required_block terf_states
scoreboard players operation @s terf_data_F += temp terf_states
scoreboard players operation @s datapipes_lib_power_storage %= warp_core_power_required_block terf_states
